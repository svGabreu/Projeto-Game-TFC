  m_Script: {fileID: 11500000, guid: aa293be4c58066044bddd82579c858f4, type: 3}
  m_Name: DialogueData_Aluno_Diabinho 1
  m_EditorClassIdentifier: Assembly-CSharp::DialogueData
  lines:
  - characterName: Diabreto
    text: "Dormindo na hora da aula, n\xE9? Que aluno PREGUI\xC7OSO!"
  - characterName: Lucas
    text: "Quem \xE9 voc\xEA?!"
  - characterName: Diabreto
    text: Eu? Sou o resultado de ANOS ignorando os estudos
  - characterName: Diabreto
    text: "E sabe o que acontece com alunos pregui\xE7osos?"
  - characterName: Diabreto
    text: "Eles ficam presos... DENTRO dos livros! Pra aprender na FOR\xC7A!"
  - characterName: Lucas
    text: "N\xE3o...espera a\xED!"
